        if _isPreparating or not _isAlive then return end
        
        setEyeContact(Holo_Head1, _targets[1])
        setEyeContact(Holo_Head2, _targets[2])
        setEyeContact(Holo_Head3, _targets[3])
        
        if _nextTimeFire < timer.systime() then
            _nextTimeFire = timer.systime() + MinRandomFire + math.random() * (MaxRandomFire-MinRandomFire)
            local index = math.random(1, 3)
            if isValid(_targets[index]) then
                pcall(function()
                    local headFire = HeadFire:new(_heads[index]:getPos(), Prop_Base, _targets[index], PropDamageMode)
                    table.insert(_activeHeadFires, headFire)
                    net.start("fire")
                    net.send()
                end)
            end
        end
    end)


    local _killingHoloAngle = 0
    function killingScene()
        local headFire = HeadFire:new(Prop_Base:getPos(), Prop_Base, owner(), true)
        headFire:explode()
        hook.add("think", "killingScene", function()
            if not isValid(Prop_Base) or not isValid(Holo_Base) then return end
            
            Holo_Base:setAngles(Prop_Base:localToWorldAngles(Angle(20,0,_killingHoloAngle)))
            
            _killingHoloAngle = _killingHoloAngle + 2
            if _killingHoloAngle > 90 then
                hook.remove("think", "killingScene")
                hideHolos()
                setEnableShield(false)
            end
        end)
    end


    local _state2_avaliable_damagetypes = {
        64,
        4096,
        67108865,
        134217728,
    }
    function isEqualDamageType(type)
        for i, f in ipairs(_state2_avaliable_damagetypes) do
            if bit.band(type, f) != 0 then
                return true
            end
        end
        return false
    end
    
    
    hook.add("EntityTakeDamage", "dmg", function(target, attacker, inflictor, amount, type, position, force)
        if not isValid(Prop_Base) 
                or target != Prop_Base 
                or attacker._isSF
                or timer.systime() < _oldLockDamageTime 
                or _isPreparating 
                or not _isAlive
                or _state == 2 and not isEqualDamageType(type) then return end
                
        _oldLockDamageTime = timer.systime() + LockDamageTime
        _health = math.max(0, _health - math.clamp(amount, 0, MaxTakeDamage))
        sendHealth()
        _lastTakeDamage = timer.systime() + AutoHealAfterTime

        if _health <= 0 then
            _isAlive = false
            killingScene()
            timer.simple(DeathTime, function()
                chip():remove()
            end)
        end
    end)
    
    
    local _HeightStep1 = 1200
    local _HeightStep2 = 500
    
    function getTargetPos(ent)
        local heightStep = _state == 1 and _HeightStep1 or _HeightStep2
        local obbCentre = ent:obbCenterW()
        local tr = trace.line(obbCentre, obbCentre + Vector(0,0,heightStep), nil, 24737, nil, false)
        if tr.Hit then
            heightStep = (tr.HitPos):getDistance(obbCentre) - 100
        end
        return ent:getPos() + Vector(0,0,heightStep)
    end
    
    
    local _oldDir = Vector()
    hook.add("think", "main", function()
        if not isValid(Holo_Tail_Bone) or not isValid(Holo_Base) then return end
        
        local systime = timer.systime()
        local x = (systime * 2) % 360
        
        Holo_Tail_Bone:setAngles(Holo_Base:localToWorldAngles(Angle(math.sin(x)*15, 0, 0)))
        
        if isValid(Holo_Tentacle1_Bone) then
            Holo_Tentacle1_Bone:setLocalAngles(Angle(math.sin(systime * 2) * 15, math.cos(systime * 3.5) * 20, 0))
        end
        if isValid(Holo_Tentacle2_Bone) then
            Holo_Tentacle2_Bone:setLocalAngles(Angle(math.cos(systime * 2) * -15, math.sin(systime * 3.5) * 20, 0))
        end
        if isValid(Holo_Tentacle3_Bone) then
            Holo_Tentacle3_Bone:setLocalAngles(Angle(math.sin(systime * 2.5) * 20, 0, math.cos(systime * 2) * 15))
        end
        
        if not _isPreparating and _isAlive and isValid(Holo_Growth) then
            if _growthScale < _maxGrowthScale then
                _growthScale = _growthScale + (0.0003 * getFrameTime())
                Holo_Growth:setScale(Vector(15, 15, 15) * _growthScale)
                
                local growthFactor = _growthScale + ((_growthScale - 1) * 0.5)
                local backwardOffset = -40 - (growthFactor * 45)
                local verticalOffset = 15 + (growthFactor * 55)
                
                Holo_Growth:setPos(Holo_Spine:localToWorld(Vector(backwardOffset, 0, verticalOffset)))
            end
        end
        
        if AiFlyEnabled and not _isPreparating and _isAlive then
            local targetPos
            local curPos = Prop_Base:getPos()
            
            if isValidPlayerOrNPC(_targets[1]) then
                targetPos = getTargetPos(_targets[1])
                _wanderPos = nil 
            else
                if not _wanderPos or curPos:getDistance(_wanderPos) < 150 or timer.systime() > _nextWanderTime then
                    local randomOffset = Vector(math.random(-1000, 1000), math.random(-1000, 1000), math.random(-200, 500))
                    _wanderPos = curPos + randomOffset
                    _nextWanderTime = timer.systime() + 12
                end
                targetPos = _wanderPos
            end
            
            local distance = targetPos:getDistance(curPos)
            if distance > 20 then
                local currentDir = _oldDir
                local targetDir = (targetPos - curPos):getNormalized()
                local nextDir = math.lerpVector(FlyHomingAccuracy/10, currentDir, targetDir)
                _oldDir = nextDir
                
                local nextStepDistance = math.clamp(distance/100, 0, isValidPlayerOrNPC(_targets[1]) and FlyVelocityMax or (FlyVelocityMax * 0.4))
                local nextPos = curPos + nextDir * nextStepDistance * getFrameTime()
                
                local wallTrace = trace.line(curPos, nextPos, {Prop_Base}, MASK.SOLID, nil, false)
                if wallTrace.Hit then
                    nextPos = wallTrace.HitPos + wallTrace.HitNormal * 15
                    _wanderPos = nil
                end
                
                local nextAng = nextDir:getAngle()
                nextAng.p = 0
                
                _propPhysObj:wake()
                _propPhysObj:setAngles(nextAng)
                _propPhysObj:setPos(nextPos)
            end
        end
    end)
    

    local _prepTime = timer.curtime()
    local _prepTimeEnd = timer.curtime() + PreparationTime
    timer.simple(PreparationTime, function()
        if not isValid(Prop_Base) or not isValid(Holo_Base) then return end
        
        local headFire = HeadFire:new(Prop_Base:getPos(), Prop_Base, owner(), true)
        headFire:explode()
        timer.simple(0.3, function()
            _isPreparating = false
            _health = Health
            setEnableShield(false)
        end)
    end)
    

    hook.add("ClientInitialized", "cl_init", function(ply)
        net.start("init")
        net.writeFloat(_prepTime)
        net.writeEntity(Holo_Base)
        net.send(ply)
    end)
    
    return
end

